---
const SITE = 'https://docsera.app';
const title = 'DocSera Pro — عيادتك كلها في مكانٍ واحد';
const description = 'منصّة DocSera Pro لإدارة العيادة: المواعيد، ملفات المرضى، التقارير، المراسلة، المحاسبة، والتحليلات في مكانٍ واحد. جرّب الباقة الكاملة ٤٥ يوماً مجاناً.';
---
<!doctype html>
<html lang="ar" dir="rtl">
<head>
<script is:inline>document.documentElement.classList.add('js');</script>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={SITE + '/pro'} />
<link rel="icon" type="image/png" href="/images/DocSera-app-icon.png" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="DocSera Pro" />
<meta property="og:locale" content="ar_AR" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={SITE + '/pro'} />
<meta property="og:image" content={SITE + '/og-image.png'} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={SITE + '/og-image.png'} />

<link rel="preload" href="/fonts/pro/Cairo-Black.ttf" as="font" type="font/ttf" crossorigin />
<link rel="preload" href="/fonts/Cairo-700.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/images/pro/logo-icon-3d.webp" as="image" />

<style is:global>
/* ---------- Fonts: reuse site woff2 (400/600/700/800) + add Black 900 ---------- */
@font-face{font-family:"Cairo";src:url("/fonts/Cairo-400.woff2") format("woff2");font-weight:400;font-display:swap;}
@font-face{font-family:"Cairo";src:url("/fonts/Cairo-600.woff2") format("woff2");font-weight:600;font-display:swap;}
@font-face{font-family:"Cairo";src:url("/fonts/Cairo-700.woff2") format("woff2");font-weight:700;font-display:swap;}
@font-face{font-family:"Cairo";src:url("/fonts/Cairo-800.woff2") format("woff2");font-weight:800;font-display:swap;}
@font-face{font-family:"Cairo";src:url("/fonts/pro/Cairo-Black.ttf") format("truetype");font-weight:900;font-display:swap;}
@font-face{font-family:"Montserrat";src:url("/fonts/Montserrat-400.woff2") format("woff2");font-weight:400;font-display:swap;}
@font-face{font-family:"Montserrat";src:url("/fonts/Montserrat-500.woff2") format("woff2");font-weight:500;font-display:swap;}
@font-face{font-family:"Montserrat";src:url("/fonts/Montserrat-600.woff2") format("woff2");font-weight:600;font-display:swap;}
@font-face{font-family:"Montserrat";src:url("/fonts/Montserrat-700.woff2") format("woff2");font-weight:700;font-display:swap;}
@font-face{font-family:"Montserrat";src:url("/fonts/pro/Montserrat-Black.ttf") format("truetype");font-weight:900;font-display:swap;}

/* ============================================================
   DocSera Pro — Marketing document styles
   Dark cinematic · RTL-first · print-ready (no backdrop-filter reliance)
   ============================================================ */

/* ---------- Fonts ---------- */

:root {
  --brand-primary:#00B5B7;
  --brand-deep:#009092;
  --brand-glow:#7DD3D4;
  --brand-aura:rgba(0,181,183,0.18);

  --bg-void:#001015;
  --bg-base:#0F1A22;
  --bg-paper:#1A252D;
  --bg-elev:#243039;

  --fg1:#E8EEF0;
  --fg2:rgba(232,238,240,0.72);
  --fg3:rgba(232,238,240,0.45);

  --warm:#FFB494;
  --warm-2:#FFA070;
  --warm-deep:#5A2A0F;

  --stroke:rgba(255,255,255,0.08);
  --stroke-soft:rgba(255,255,255,0.06);
  --stroke-strong:rgba(255,255,255,0.16);

  --font-ar:"Cairo","Segoe UI",system-ui,sans-serif;
  --font-en:"Montserrat","Inter",system-ui,sans-serif;

  --shadow-md:0 8px 16px -4px rgba(0,16,21,0.50), 0 2px 6px rgba(0,181,183,0.06);
  --shadow-lg:0 24px 48px -12px rgba(0,16,21,0.55), 0 8px 16px -8px rgba(0,16,21,0.6);
  --shadow-xl:0 40px 80px -20px rgba(0,16,21,0.70), 0 24px 48px -12px rgba(0,181,183,0.18);

  --r-sm:10px; --r-md:14px; --r-lg:20px; --r-xl:24px; --r-2xl:32px; --r-pill:999px;
}

* { box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  margin:0;
  position:relative;
  direction:rtl;
  background:var(--bg-void);
  color:var(--fg1);
  font-family:var(--font-ar);
  -webkit-font-smoothing:antialiased;
  text-rendering:optimizeLegibility;
  overflow-x:hidden;
}

/* ============================================================
   Atmosphere
   ============================================================ */
.atmos { position:fixed; top:0; left:0; right:0; height:100vh; z-index:0; pointer-events:none; overflow:hidden;
  background:
    radial-gradient(1200px 560px at 50% -60px, #11303a 0%, #0c2129 26%, #06141b 52%, #02101500 100%),
    linear-gradient(180deg,#04121a 0%, #041018 48%, #03121a 74%, #020d12 100%);
}
.atmos .orb { position:absolute; border-radius:999px; filter:blur(70px); mix-blend-mode:screen; opacity:0.9; }
.atmos .grid {
  position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
  background-size:84px 84px;
  -webkit-mask-image:radial-gradient(ellipse 70% 50% at 50% 0%, #000 20%, transparent 72%);
  mask-image:radial-gradient(ellipse 70% 50% at 50% 0%, #000 20%, transparent 72%);
}
.atmos .noise { position:absolute; inset:0; opacity:0.05; mix-blend-mode:overlay; background-size:240px; }

/* ============================================================
   Layout
   ============================================================ */
.shell { position:relative; z-index:2; }
.wrap { width:min(1180px, 92vw); margin-inline:auto; }
.narrow { width:min(940px, 92vw); margin-inline:auto; }

/* ---------- Top brand bar ---------- */
.topbar { display:flex; align-items:center; justify-content:space-between; padding:30px 0 8px; }
.brand { display:flex; align-items:center; gap:12px; }
.brand img { height:34px; width:auto; filter:drop-shadow(0 6px 16px rgba(0,181,183,0.35)); }
.brand .wm { font-family:var(--font-en); font-weight:900; font-size:20px; letter-spacing:-0.025em; color:var(--fg1); direction:ltr; }
.brand .wm sup { font-size:0.5em; color:var(--brand-glow); font-weight:700; vertical-align:0.5em; margin-inline-start:3px; letter-spacing:0.06em; }
.topbar .meta { font-family:var(--font-en); font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--fg3); }

/* ---------- Badge / eyebrow ---------- */
.eyebrow { display:inline-flex; align-items:center; gap:9px; padding:8px 16px; border-radius:999px;
  background:rgba(255,255,255,0.05); border:1px solid var(--stroke); 
  font-family:var(--font-ar); font-weight:700; font-size:13.5px; color:var(--fg2); }
.eyebrow .dot { width:7px; height:7px; border-radius:999px; background:var(--brand-glow); box-shadow:0 0 12px var(--brand-glow); flex:none; }
.eyebrow.warm { background:rgba(255,180,148,0.12); border-color:rgba(255,180,148,0.28); color:#FFD9C4; }
.eyebrow.warm .dot { background:var(--warm); box-shadow:0 0 12px var(--warm); }

/* "First 100" seal */
.seal { display:inline-flex; align-items:center; gap:9px; padding:8px 16px 8px 14px; border-radius:999px;
  background:linear-gradient(135deg, rgba(255,180,148,0.20), rgba(255,160,112,0.10));
  border:1px solid rgba(255,180,148,0.40); color:#FFD9C4;
  font-family:var(--font-ar); font-weight:800; font-size:13.5px; }
.seal svg { width:16px; height:16px; color:var(--warm); }

/* ============================================================
   Hero
   ============================================================ */
.hero { padding:46px 0 30px; }
.hero-grid { display:grid; grid-template-columns:1.04fr 0.96fr; gap:54px; align-items:center; }
.hero h1 { font-family:var(--font-ar); font-weight:900; font-size:clamp(40px,5vw,68px); line-height:1.18;
  letter-spacing:-0.01em; color:var(--fg1); margin:22px 0 8px; max-width:15ch; text-wrap:balance; }
.hero h1 .grad { background:linear-gradient(180deg,#E8EEF0 0%,#7DD3D4 92%); -webkit-background-clip:text; background-clip:text; color:transparent; }
.hero .en-line { font-family:var(--font-en); font-weight:500; font-size:17px; letter-spacing:0.005em; color:var(--fg3); margin:0 0 22px; direction:ltr; }
.hero .lede { font-family:var(--font-ar); font-weight:500; font-size:19px; line-height:1.7; color:var(--fg2); max-width:34ch; margin:0 0 30px; }
.hero-cta-row { display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:22px; }
.hero-badges { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }

/* ---------- Buttons ---------- */
.btn { display:inline-flex; align-items:center; gap:10px; font-family:var(--font-ar); font-weight:800; white-space:nowrap;
  border:none; cursor:pointer; text-decoration:none; transition:transform 160ms cubic-bezier(.32,.72,0,1), box-shadow 160ms; }
.btn svg { width:19px; height:19px; flex:none; }
.btn-wa { font-size:16.5px; color:#001015; padding:15px 26px; border-radius:12px;
  background:linear-gradient(180deg,#7DD3D4,#00B5B7);
  box-shadow:0 12px 28px -6px rgba(0,181,183,0.55), inset 0 1px 0 rgba(255,255,255,0.35); }
.btn-wa:hover { transform:translateY(-2px); box-shadow:0 16px 34px -6px rgba(0,181,183,0.65), inset 0 1px 0 rgba(255,255,255,0.40); }
.btn-wa.lg { font-size:18px; padding:18px 34px; }
.btn-ghost { font-size:15px; color:var(--fg2); padding:14px 18px; border-radius:12px; background:transparent;
  border:1px solid var(--stroke-strong); }
.btn-ghost:hover { color:var(--fg1); border-color:rgba(255,255,255,0.3); background:rgba(255,255,255,0.04); }
.wa-ico { color:#001015; }

/* ============================================================
   Section blocks
   ============================================================ */
.block { padding:54px 0; position:relative; }
.block + .block { border-top:1px solid var(--stroke-soft); }
.block-head { display:flex; align-items:flex-start; gap:18px; margin-bottom:34px; }
.petal-idx { position:relative; flex:none; width:50px; height:50px; display:grid; place-items:center; }
.petal-idx img { position:absolute; inset:0; width:100%; height:100%; opacity:0.92;
  filter:drop-shadow(0 4px 10px rgba(0,181,183,0.3)); }
.petal-idx span { position:relative; font-family:var(--font-ar); font-weight:900; font-size:19px; color:#001015; }
.block-head .ht { flex:1; }
.kicker { font-family:var(--font-en); font-weight:700; font-size:11.5px; letter-spacing:0.16em; text-transform:uppercase;
  color:var(--brand-glow); direction:ltr; display:block; margin-bottom:8px; }
.block-head h2 { font-family:var(--font-ar); font-weight:900; font-size:clamp(28px,3.4vw,42px); line-height:1.28;
  color:var(--fg1); margin:0; letter-spacing:-0.005em; text-wrap:balance; }
.block-head .en-sub { font-family:var(--font-en); font-weight:500; font-size:13.5px; color:var(--fg3); direction:ltr; margin-top:7px; }
.lead { font-family:var(--font-ar); font-weight:500; font-size:18px; line-height:1.85; color:var(--fg2); max-width:60ch; }

/* feature 2-col */
.feature { display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:center; }
.feature.flip .fviz { order:-1; }
.fbody .lead { margin-bottom:22px; }

/* ---------- Glass panel ---------- */
.glass { position:relative; border-radius:var(--r-xl); overflow:hidden;
  background:linear-gradient(150deg, rgba(255,255,255,0.085) 0%, rgba(255,255,255,0.028) 46%, rgba(255,255,255,0.06) 100%);
  border:1px solid var(--stroke-strong);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.16), inset 0 -1px 0 rgba(0,0,0,0.18), var(--shadow-lg); }
.glass::after { content:""; position:absolute; top:0; left:0; right:0; height:1px;
  background:linear-gradient(90deg, transparent, rgba(255,255,255,0.42), transparent); }
.glass-soft { background:linear-gradient(150deg, rgba(36,48,57,0.55), rgba(15,26,34,0.55));
  border:1px solid var(--stroke); box-shadow:inset 0 1px 0 rgba(255,255,255,0.06), var(--shadow-md); border-radius:var(--r-xl); }

/* ---------- Feature bullet list ---------- */
.checks { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:14px; }
.checks li { display:flex; align-items:flex-start; gap:13px; font-family:var(--font-ar); font-weight:500;
  font-size:16.5px; line-height:1.7; color:var(--fg1); }
.checks li .tick { flex:none; width:15px; height:15px; margin-top:5px; padding:4px; box-sizing:content-box;
  color:var(--brand-primary); background:rgba(0,181,183,0.14); border-radius:999px; }
.checks li .tick svg { width:15px; height:15px; display:block; }
.checks.warm li .tick { color:var(--warm); background:rgba(255,180,148,0.16); }

.fineprint { font-family:var(--font-ar); font-weight:500; font-size:13.5px; line-height:1.7; color:var(--fg3);
  margin-top:18px; padding-inline-start:14px; border-inline-start:2px solid var(--stroke-strong); }

/* ============================================================
   Block 2 — tools merging
   ============================================================ */
.merge-viz { padding:36px; display:flex; flex-direction:column; align-items:center; gap:22px; }
.scatter { display:flex; flex-wrap:wrap; gap:11px; justify-content:center; max-width:330px; }
.chip { display:inline-flex; align-items:center; gap:8px; padding:9px 14px; border-radius:12px;
  background:rgba(255,255,255,0.04); border:1px solid var(--stroke); font-family:var(--font-ar); font-weight:600;
  font-size:13.5px; color:var(--fg2); }
.chip svg { width:15px; height:15px; color:var(--fg3); }
.merge-arrow { color:var(--brand-glow); display:grid; place-items:center; }
.merge-arrow svg { width:26px; height:26px; }
.one-card { width:100%; display:flex; align-items:center; gap:14px; padding:18px 20px; border-radius:var(--r-lg);
  background:linear-gradient(135deg, rgba(0,181,183,0.16), rgba(0,181,183,0.04)); border:1px solid rgba(0,181,183,0.35); }
.one-card .mk { width:38px; height:38px; flex:none; }
.one-card b { font-family:var(--font-ar); font-weight:800; font-size:17px; color:var(--fg1); display:block; }
.one-card span { font-family:var(--font-en); font-size:11.5px; letter-spacing:0.04em; color:var(--brand-glow); direction:ltr; }

/* ============================================================
   Mock UI primitives (device screens)
   ============================================================ */
.mock { padding:18px; }
.mock-bar { display:flex; align-items:center; justify-content:space-between; padding-bottom:14px; margin-bottom:14px;
  border-bottom:1px solid var(--stroke); }
.mock-title { font-family:var(--font-ar); font-weight:800; font-size:15px; color:var(--fg1); }
.mock-dot { display:inline-flex; gap:5px; }
.mock-dot i { width:8px; height:8px; border-radius:999px; background:var(--stroke-strong); display:block; }

/* roster rows */
.roster { display:flex; flex-direction:column; gap:9px; }
.rrow { display:grid; grid-template-columns:auto 1fr auto; align-items:center; gap:12px; padding:12px 14px;
  border-radius:var(--r-md); background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); }
.rrow .av { width:34px; height:34px; border-radius:999px; flex:none; display:grid; place-items:center;
  font-family:var(--font-ar); font-weight:800; font-size:14px; color:#001015;
  background:linear-gradient(135deg,#7DD3D4,#00B5B7); }
.rrow .nm { font-family:var(--font-ar); font-weight:700; font-size:14.5px; color:var(--fg1); }
.rrow .tm { font-family:var(--font-en); font-weight:700; font-size:13px; color:var(--fg3); direction:ltr; font-variant-numeric:tabular-nums; }
.pill { font-family:var(--font-ar); font-weight:700; font-size:11.5px; padding:4px 10px; border-radius:999px; white-space:nowrap; }
.pill.wait { background:rgba(255,193,7,0.16); color:#FFD66B; }
.pill.now { background:rgba(0,181,183,0.18); color:var(--brand-glow); }
.pill.done { background:rgba(255,255,255,0.06); color:var(--fg3); }

/* invoice mock */
.inv { display:flex; flex-direction:column; gap:11px; }
.inv-line { display:flex; align-items:center; justify-content:space-between; font-family:var(--font-ar);
  font-weight:600; font-size:14px; color:var(--fg2); }
.inv-line .amt { font-family:var(--font-en); font-weight:800; font-variant-numeric:tabular-nums; color:var(--fg1); direction:ltr; }
.inv-total { display:flex; align-items:center; justify-content:space-between; margin-top:6px; padding-top:14px;
  border-top:1px dashed var(--stroke-strong); }
.inv-total b { font-family:var(--font-ar); font-weight:800; font-size:16px; color:var(--fg1); }
.inv-total .amt { font-family:var(--font-en); font-weight:900; font-size:22px; color:var(--brand-glow); direction:ltr; font-variant-numeric:tabular-nums; }
.curr-tags { display:flex; gap:8px; margin-top:14px; }
.curr-tags .ct { font-family:var(--font-ar); font-weight:700; font-size:12px; padding:5px 12px; border-radius:999px;
  background:rgba(255,255,255,0.04); border:1px solid var(--stroke); color:var(--fg2); }

/* chat mock */
.chat { display:flex; flex-direction:column; gap:10px; }
.bub { max-width:78%; padding:11px 15px; border-radius:16px; font-family:var(--font-ar); font-weight:500; font-size:14px; line-height:1.6; }
.bub.them { align-self:flex-start; background:rgba(255,255,255,0.05); border:1px solid var(--stroke); color:var(--fg1); border-bottom-right-radius:5px; }
.bub.me { align-self:flex-end; background:linear-gradient(180deg,#0c8a8c,#0a7173); color:#EAFEFE; border-bottom-left-radius:5px; }
.bub .v { display:flex; align-items:center; gap:9px; }
.bub .wave { display:inline-flex; gap:3px; align-items:center; }
.bub .wave i { width:3px; border-radius:3px; background:currentColor; opacity:0.8; display:block; }
.chat-meta { font-family:var(--font-en); font-size:11px; color:var(--fg3); text-align:center; direction:ltr; letter-spacing:0.04em; }

/* KPI tiles + chart */
.kpi-row { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:18px; }
.kpi { padding:16px; border-radius:var(--r-md); background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); }
.kpi .n { font-family:var(--font-en); font-weight:900; font-size:30px; color:var(--fg1); line-height:1; font-variant-numeric:tabular-nums; direction:ltr; }
.kpi .n small { font-size:14px; color:var(--fg3); font-weight:700; }
.kpi .l { font-family:var(--font-ar); font-weight:600; font-size:12.5px; color:var(--fg3); margin-top:7px; }
.bars { display:flex; align-items:flex-end; gap:9px; height:96px; padding-top:6px; }
.bars .b { flex:1; border-radius:6px 6px 3px 3px; background:linear-gradient(180deg,#7DD3D4,#0a7173); opacity:0.85; }
.bars .b.peak { background:linear-gradient(180deg,#FFC9AE,#FF9F70); opacity:1; }
.bars-x { display:flex; gap:9px; margin-top:8px; }
.bars-x span { flex:1; text-align:center; font-family:var(--font-en); font-size:10px; color:var(--fg3); direction:ltr; }

/* dental chart */
.teeth { display:flex; flex-direction:column; gap:10px; }
.teeth-row { display:flex; gap:6px; justify-content:center; }
.tooth { width:30px; height:38px; border-radius:7px 7px 9px 9px; background:rgba(255,255,255,0.05);
  border:1px solid var(--stroke); display:grid; place-items:center; font-family:var(--font-en); font-size:10px; color:var(--fg3); }
.tooth.fill { background:rgba(0,181,183,0.22); border-color:rgba(0,181,183,0.5); color:var(--brand-glow); }
.tooth.warm { background:rgba(255,180,148,0.2); border-color:rgba(255,180,148,0.5); color:var(--warm); }
.teeth-legend { display:flex; gap:16px; justify-content:center; margin-top:6px; font-family:var(--font-ar); font-size:12px; color:var(--fg3); }
.teeth-legend span { display:inline-flex; align-items:center; gap:7px; }
.teeth-legend i { width:11px; height:11px; border-radius:4px; display:block; }

/* team rows */
.team { display:flex; flex-direction:column; gap:10px; }
.tmrow { display:grid; grid-template-columns:auto 1fr auto; align-items:center; gap:13px; padding:13px 15px;
  border-radius:var(--r-md); background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); }
.tmrow .av { width:36px; height:36px; border-radius:999px; flex:none; display:grid; place-items:center;
  font-family:var(--font-ar); font-weight:800; font-size:14px; color:#001015; background:linear-gradient(135deg,#7DD3D4,#00B5B7); }
.tmrow .who b { font-family:var(--font-ar); font-weight:700; font-size:14.5px; color:var(--fg1); display:block; }
.tmrow .who span { font-family:var(--font-ar); font-weight:500; font-size:12.5px; color:var(--fg3); }
.toggle { width:42px; height:24px; border-radius:999px; background:rgba(0,181,183,0.3); position:relative; flex:none; }
.toggle::after { content:""; position:absolute; top:3px; left:3px; width:18px; height:18px; border-radius:999px; background:#E8EEF0; }
.toggle.off { background:rgba(255,255,255,0.08); }
.toggle.off::after { left:auto; right:3px; background:var(--fg3); }

/* ============================================================
   Block 11 — Growth (warm accent)
   ============================================================ */
.growth { position:relative; border-radius:var(--r-2xl); padding:48px; overflow:hidden;
  background:
    radial-gradient(520px circle at 88% 6%, rgba(255,180,148,0.16), transparent 56%),
    radial-gradient(520px circle at 6% 92%, rgba(0,181,183,0.14), transparent 56%),
    linear-gradient(160deg, #20262b 0%, #161d23 100%);
  border:1px solid rgba(255,180,148,0.22);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.10), 0 40px 80px -24px rgba(0,16,21,0.7); }
.growth-head { display:flex; align-items:flex-start; gap:18px; margin-bottom:32px; }
.growth-head h2 { font-family:var(--font-ar); font-weight:900; font-size:clamp(28px,3.4vw,40px); line-height:1.3; margin:0; color:var(--fg1); }
.growth-head .en-sub { font-family:var(--font-en); font-weight:600; font-size:13px; color:var(--warm); direction:ltr; margin-top:7px; letter-spacing:0.04em; }
.growth-grid { display:grid; grid-template-columns:1.15fr 0.85fr; gap:40px; align-items:start; }
.growth .checks li { font-size:16px; }
.growth .checks li b { font-weight:800; color:var(--fg1); }

/* offer card + gift reminder mocks */
.gcard-stack { display:flex; flex-direction:column; gap:16px; }
.offer-card { position:relative; border-radius:var(--r-lg); padding:22px; overflow:hidden;
  background:linear-gradient(150deg, rgba(255,180,148,0.16), rgba(255,160,112,0.05));
  border:1px solid rgba(255,180,148,0.4); }
.offer-card .lbl { font-family:var(--font-en); font-weight:700; font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--warm); direction:ltr; }
.offer-card .big { font-family:var(--font-ar); font-weight:900; font-size:23px; color:#FFE3D2; margin:8px 0 4px; }
.offer-card .sub { font-family:var(--font-ar); font-weight:500; font-size:13.5px; color:var(--fg2); }
.offer-card .barcode { display:flex; gap:3px; margin-top:18px; height:34px; align-items:stretch; opacity:0.7; }
.offer-card .barcode i { background:#FFE3D2; border-radius:1px; display:block; }
.gift { display:flex; align-items:center; gap:14px; padding:16px 18px; border-radius:var(--r-lg);
  background:rgba(255,255,255,0.04); border:1px solid var(--stroke); }
.gift .gi { width:42px; height:42px; flex:none; border-radius:12px; display:grid; place-items:center;
  background:rgba(255,180,148,0.16); color:var(--warm); }
.gift .gi svg { width:22px; height:22px; }
.gift .gt b { font-family:var(--font-ar); font-weight:700; font-size:15px; color:var(--fg1); display:block; }
.gift .gt span { font-family:var(--font-ar); font-weight:500; font-size:13px; color:var(--fg3); }
.loyalty { display:flex; align-items:center; gap:6px; padding:14px 18px; border-radius:var(--r-lg);
  background:rgba(0,181,183,0.1); border:1px solid rgba(0,181,183,0.28); }
.loyalty .dots { display:inline-flex; gap:5px; }
.loyalty .dots i { width:13px; height:13px; border-radius:999px; background:var(--brand-glow); display:block; }
.loyalty .dots i.empty { background:transparent; border:1.5px solid rgba(125,211,212,0.45); }
.loyalty .lt { font-family:var(--font-ar); font-weight:700; font-size:14px; color:var(--fg1); margin-inline-end:auto; }

/* ============================================================
   Privacy / why / cards rows
   ============================================================ */
.cards-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
.icard { padding:26px 24px; border-radius:var(--r-xl); background:linear-gradient(150deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
  border:1px solid var(--stroke); box-shadow:var(--shadow-md); }
.icard .ic { width:46px; height:46px; border-radius:13px; display:grid; place-items:center; margin-bottom:16px;
  background:rgba(0,181,183,0.14); color:var(--brand-primary); }
.icard .ic svg { width:23px; height:23px; }
.icard h3 { font-family:var(--font-ar); font-weight:800; font-size:18px; color:var(--fg1); margin:0 0 8px; }
.icard p { font-family:var(--font-ar); font-weight:500; font-size:14.5px; line-height:1.7; color:var(--fg2); margin:0; }

.compare { display:flex; flex-direction:column; gap:16px; }
.crow { display:grid; grid-template-columns:1fr auto 1fr; align-items:center; gap:20px; padding:24px 26px;
  border-radius:var(--r-xl); background:linear-gradient(150deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02));
  border:1px solid var(--stroke); }
.crow .other { font-family:var(--font-ar); font-weight:500; font-size:16px; color:var(--fg3); line-height:1.6; }
.crow .ours { font-family:var(--font-ar); font-weight:700; font-size:16.5px; color:var(--fg1); line-height:1.7; }
.crow .vs { flex:none; width:40px; height:40px; border-radius:999px; display:grid; place-items:center;
  background:rgba(0,181,183,0.14); color:var(--brand-glow); }
.crow .vs svg { width:20px; height:20px; }

/* try-it-free */
.tryfree { display:grid; grid-template-columns:1fr auto; gap:40px; align-items:center; padding:44px;
  border-radius:var(--r-2xl); position:relative; overflow:hidden;
  background:radial-gradient(600px circle at 12% 0%, rgba(0,181,183,0.16), transparent 55%), linear-gradient(160deg,#172128,#0e171d);
  border:1px solid var(--stroke); box-shadow:var(--shadow-xl); }
.ribbon { position:absolute; top:22px; left:-44px; transform:rotate(-45deg); background:linear-gradient(135deg,#7DD3D4,#00B5B7);
  color:#001015; font-family:var(--font-ar); font-weight:900; font-size:13px; padding:7px 56px; box-shadow:0 8px 18px -4px rgba(0,181,183,0.5); }
.big-seal { flex:none; width:148px; height:148px; border-radius:999px; display:grid; place-items:center; text-align:center;
  background:radial-gradient(circle at 50% 30%, rgba(255,180,148,0.25), rgba(255,160,112,0.06));
  border:2px solid rgba(255,180,148,0.5); box-shadow:0 0 0 8px rgba(255,180,148,0.06), inset 0 2px 0 rgba(255,255,255,0.2); }
.big-seal .num { font-family:var(--font-en); font-weight:900; font-size:46px; color:#FFE3D2; line-height:0.9; direction:ltr; }
.big-seal .cap { font-family:var(--font-ar); font-weight:800; font-size:13px; color:var(--warm); margin-top:4px; }

/* ============================================================
   FAQ (static, open)
   ============================================================ */
.faq { display:flex; flex-direction:column; gap:14px; }
.qa { padding:24px 26px; border-radius:var(--r-xl); background:linear-gradient(150deg, rgba(255,255,255,0.045), rgba(255,255,255,0.015));
  border:1px solid var(--stroke); }
.qa .q { display:flex; align-items:flex-start; gap:13px; font-family:var(--font-ar); font-weight:800; font-size:18px; color:var(--fg1); margin-bottom:11px; }
.qa .q .qm { flex:none; width:26px; height:26px; border-radius:999px; display:grid; place-items:center; margin-top:1px;
  background:rgba(0,181,183,0.16); color:var(--brand-glow); }
.qa .q .qm svg { width:15px; height:15px; }
.qa .a { font-family:var(--font-ar); font-weight:500; font-size:15.5px; line-height:1.85; color:var(--fg2); padding-inline-start:39px; }

/* ============================================================
   Closing CTA
   ============================================================ */
.closing { text-align:center; padding:80px 0 96px; position:relative; }
.closing .mk { width:64px; height:64px; margin:0 auto 26px; filter:drop-shadow(0 10px 30px rgba(0,181,183,0.45)); }
.closing h2 { font-family:var(--font-ar); font-weight:900; font-size:clamp(34px,4.6vw,58px); line-height:1.22;
  color:var(--fg1); margin:0 auto 18px; max-width:18ch; text-wrap:balance; }
.closing .en-line { font-family:var(--font-en); font-weight:500; font-size:15px; color:var(--fg3); direction:ltr; margin-bottom:10px; }
.closing .body { font-family:var(--font-ar); font-weight:500; font-size:18px; line-height:1.8; color:var(--fg2);
  max-width:52ch; margin:0 auto 34px; }
.closing .cta-row { display:flex; align-items:center; justify-content:center; gap:18px; flex-wrap:wrap; margin-bottom:26px; }
.quiet { font-family:var(--font-ar); font-weight:700; font-size:15px; color:var(--brand-glow); text-decoration:none; padding:14px 8px; white-space:nowrap; }
.quiet:hover { text-decoration:underline; }
.reassure { display:inline-flex; gap:26px; flex-wrap:wrap; justify-content:center; font-family:var(--font-ar);
  font-weight:600; font-size:14px; color:var(--fg2); }
.reassure span { display:inline-flex; align-items:center; gap:8px; }
.reassure svg { width:16px; height:16px; color:var(--brand-glow); }

/* footer */
.foot { text-align:center; padding:30px 0 50px; border-top:1px solid var(--stroke-soft); }
.foot .fb { display:flex; align-items:center; justify-content:center; gap:10px; margin-bottom:10px; }
.foot .fb img { height:26px; }
.foot .fn { font-family:var(--font-ar); font-size:13px; color:var(--fg3); line-height:1.8; }

/* ============================================================
   Responsive
   ============================================================ */
@media (max-width:880px) {
  .hero-grid, .feature, .growth-grid, .tryfree, .growth-head { grid-template-columns:1fr; }
  .feature.flip .fviz { order:0; }
  .cards-3, .kpi-row { grid-template-columns:1fr; }
  .crow { grid-template-columns:1fr; text-align:center; gap:12px; }
  .crow .vs { margin:0 auto; transform:rotate(90deg); }
  .tryfree { justify-items:center; text-align:center; }
}

/* ============================================================
   Print — tall poster export
   ============================================================ */
/* ============================================================
   Additions — hero mock, file/report/search mocks, misc
   ============================================================ */

/* hero device */
.hero-viz { position:relative; }
.hero-mock { padding:20px; }
.hero-mock-foot { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-top:16px; padding-top:16px; border-top:1px solid var(--stroke); }
.hmf-kpi { text-align:center; }
.hmf-kpi b { font-family:var(--font-en); font-weight:900; font-size:26px; color:var(--brand-glow); line-height:1; direction:ltr; display:block; }
.hmf-kpi span { font-family:var(--font-ar); font-weight:600; font-size:12.5px; color:var(--fg3); display:block; margin-top:5px; }
.hero-float { position:absolute; inset-inline-start:-26px; bottom:-22px; display:flex; align-items:center; gap:12px;
  padding:13px 17px; border-radius:var(--r-lg); max-width:240px; }
.hero-float .mk { width:34px; height:34px; flex:none; }
.hero-float b { font-family:var(--font-ar); font-weight:800; font-size:14.5px; color:var(--fg1); display:block; }
.hero-float span { font-family:var(--font-ar); font-weight:600; font-size:12px; color:var(--brand-glow); direction:rtl; }

/* patient file mock */
.file-head { display:flex; align-items:center; gap:14px; padding-bottom:16px; margin-bottom:16px; border-bottom:1px solid var(--stroke); }
.av.lg { width:48px; height:48px; border-radius:999px; flex:none; display:grid; place-items:center;
  font-family:var(--font-ar); font-weight:800; font-size:18px; color:#001015; background:linear-gradient(135deg,#7DD3D4,#00B5B7); }
.av.sm { width:30px; height:30px; border-radius:999px; flex:none; display:grid; place-items:center;
  font-family:var(--font-ar); font-weight:800; font-size:13px; color:var(--fg3); background:rgba(255,255,255,0.06); }
.file-id b { font-family:var(--font-ar); font-weight:800; font-size:17px; color:var(--fg1); display:block; }
.file-id span { font-family:var(--font-ar); font-weight:600; font-size:13px; color:var(--fg3); }
.file-tabs { display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; }
.file-tabs .ft { font-family:var(--font-ar); font-weight:700; font-size:12.5px; padding:7px 14px; border-radius:999px;
  background:rgba(255,255,255,0.04); border:1px solid var(--stroke); color:var(--fg3); }
.file-tabs .ft.active { background:rgba(0,181,183,0.16); border-color:rgba(0,181,183,0.4); color:var(--brand-glow); }
.file-docs { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.file-docs .doc { display:flex; align-items:center; gap:11px; padding:14px; border-radius:var(--r-md);
  background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); font-family:var(--font-ar); font-weight:600; font-size:13.5px; color:var(--fg1); }
.file-docs .doc svg { width:18px; height:18px; color:var(--brand-glow); flex:none; }

/* visit report mock */
.report-pdf { display:inline-flex; align-items:center; gap:7px; font-family:var(--font-ar); font-weight:700; font-size:12.5px;
  padding:6px 12px; border-radius:999px; background:rgba(0,181,183,0.14); color:var(--brand-glow); }
.report-pdf svg { width:15px; height:15px; }
.report-body { display:flex; flex-direction:column; gap:13px; }
.report-body .rl { display:flex; gap:14px; }
.report-body .rk { flex:none; width:58px; font-family:var(--font-ar); font-weight:700; font-size:13px; color:var(--fg3); padding-top:1px; }
.report-body .rv { font-family:var(--font-ar); font-weight:600; font-size:14.5px; color:var(--fg1); line-height:1.6; }
.score { display:flex; align-items:center; justify-content:space-between; padding:14px 16px; border-radius:var(--r-md);
  background:rgba(0,181,183,0.1); border:1px solid rgba(0,181,183,0.26); }
.score-k { font-family:var(--font-ar); font-weight:700; font-size:13px; color:var(--brand-glow); }
.score-v b { font-family:var(--font-en); font-weight:900; font-size:30px; color:var(--fg1); direction:ltr; }
.score-v small { font-family:var(--font-en); font-weight:700; font-size:14px; color:var(--fg3); }

/* messaging lock tag */
.lock-tag { display:inline-flex; align-items:center; gap:6px; font-family:var(--font-ar); font-weight:700; font-size:12px;
  padding:5px 11px; border-radius:999px; background:rgba(255,255,255,0.05); border:1px solid var(--stroke); color:var(--fg2); }
.lock-tag svg { width:13px; height:13px; color:var(--brand-glow); }

/* dental muted tag */
.muted-tag { font-family:var(--font-ar); font-weight:600; font-size:15px; color:var(--fg3); margin-inline-start:8px; }

/* growth warm petal + fine */
.petal-idx.warm img { filter:drop-shadow(0 4px 10px rgba(255,180,148,0.4)); }
.petal-idx.warm span { color:#5A2A0F; font-size:22px; }
.kicker.warm { color:var(--warm); }
.fineprint.warm-fine { border-inline-start-color:rgba(255,180,148,0.5); color:#E9C3B0; }

/* centered block head (block 12) */
.block-head.center { flex-direction:column; align-items:center; text-align:center; gap:0; margin-bottom:20px; }
.center-lead { margin-inline:auto; text-align:center; max-width:62ch; }

/* search visibility mock (block 12) */
.search-viz { max-width:560px; margin:34px auto 0; padding:22px; border-radius:var(--r-xl); }
.search-bar { display:flex; align-items:center; gap:11px; padding:13px 16px; border-radius:var(--r-md);
  background:rgba(255,255,255,0.04); border:1px solid var(--stroke); font-family:var(--font-ar); font-weight:600; font-size:14.5px; color:var(--fg2); margin-bottom:14px; }
.search-bar svg { width:18px; height:18px; color:var(--fg3); flex:none; }
.search-results { display:flex; flex-direction:column; gap:9px; }
.sres { display:flex; align-items:center; gap:12px; padding:13px 15px; border-radius:var(--r-md);
  background:rgba(255,255,255,0.025); border:1px solid var(--stroke-soft); }
.sres.on { background:linear-gradient(135deg, rgba(0,181,183,0.16), rgba(0,181,183,0.04)); border-color:rgba(0,181,183,0.4); }
.sres .mk { width:34px; height:34px; flex:none; }
.sres b { font-family:var(--font-ar); font-weight:800; font-size:14.5px; color:var(--fg1); display:block; }
.sres span { font-family:var(--font-ar); font-weight:500; font-size:12.5px; color:var(--fg3); }
.sres .pill { margin-inline-start:auto; }

/* try-it-free body */
.tryfree-body .block-head { margin-bottom:22px; }
.tryfree-body .checks li { font-size:16px; }

/* footer logo */
.foot .fb img { height:30px; opacity:0.9; }

/* ============================================================
   REVISION — section marker, app-accurate mocks
   ============================================================ */

/* header full logo */
.brand img { height:32px; }

/* section number marker (replaces logo+digit) */
.sec-no { flex:none; width:52px; height:52px; border-radius:15px; display:grid; place-items:center;
  font-family:var(--font-en); font-weight:900; font-size:20px; color:var(--brand-glow); direction:ltr;
  font-variant-numeric:tabular-nums; letter-spacing:-0.02em;
  background:linear-gradient(150deg, rgba(0,181,183,0.18), rgba(0,181,183,0.045));
  border:1px solid rgba(0,181,183,0.32);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.12), 0 6px 16px -8px rgba(0,181,183,0.5); }
.sec-no svg { width:22px; height:22px; }
.sec-no.warm { color:var(--warm);
  background:linear-gradient(150deg, rgba(255,180,148,0.2), rgba(255,160,112,0.05));
  border-color:rgba(255,180,148,0.36); box-shadow:inset 0 1px 0 rgba(255,255,255,0.12), 0 6px 16px -8px rgba(255,160,112,0.5); }

/* founding strip (block 12) */
.founding-strip { display:flex; flex-wrap:wrap; gap:12px; margin-top:26px; }
.fchip { display:inline-flex; align-items:center; gap:9px; padding:11px 18px; border-radius:999px;
  font-family:var(--font-ar); font-weight:700; font-size:14px; color:var(--fg1);
  background:rgba(255,255,255,0.04); border:1px solid var(--stroke); }
.fchip svg { width:17px; height:17px; color:var(--brand-glow); }
.fchip.warm { background:linear-gradient(135deg, rgba(255,180,148,0.18), rgba(255,160,112,0.06));
  border-color:rgba(255,180,148,0.4); color:#FFD9C4; }
.fchip.warm svg { color:var(--warm); }

/* ----- Patient file mock ----- */
.pf { position:relative; }
.pf-brand { position:absolute; top:16px; left:16px; right:auto; display:inline-flex; align-items:center; gap:7px;
  padding:5px 11px 5px 8px; border-radius:999px; background:rgba(0,181,183,0.14); border:1px solid rgba(0,181,183,0.32);
  font-family:var(--font-en); font-weight:700; font-size:11px; color:var(--brand-glow); direction:ltr; }
.pf-brand img { width:14px; height:14px; }
.pf-head { display:flex; justify-content:flex-start; padding-bottom:16px; margin-bottom:14px; border-bottom:1px solid var(--stroke); }
.pf-id { display:flex; align-items:center; gap:13px; }
.pf-id b { font-family:var(--font-ar); font-weight:800; font-size:17px; color:var(--fg1); display:block; }
.pf-id span { font-family:var(--font-ar); font-weight:600; font-size:13px; color:var(--fg3); }
.pf-tabs { display:flex; gap:7px; margin-bottom:16px; flex-wrap:wrap; }
.pf-tabs .ft { font-family:var(--font-ar); font-weight:700; font-size:12px; padding:7px 13px; border-radius:999px;
  background:rgba(255,255,255,0.04); border:1px solid var(--stroke); color:var(--fg3); white-space:nowrap; }
.pf-tabs .ft.active { background:rgba(0,181,183,0.18); border-color:rgba(0,181,183,0.42); color:var(--brand-glow); }
.pf-vitals { border-radius:var(--r-md); background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); padding:16px; margin-bottom:14px; }
.pf-sec-t { display:flex; align-items:center; gap:9px; font-family:var(--font-ar); font-weight:800; font-size:14px; color:var(--fg1); margin-bottom:14px; }
.pf-sec-t svg { width:17px; height:17px; color:var(--brand-glow); }
.pf-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:14px; }
.pf-vital { text-align:center; padding:12px 6px; border-radius:var(--r-sm); background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); }
.pf-vital .vk { display:block; font-family:var(--font-ar); font-weight:600; font-size:11.5px; color:var(--fg3); margin-bottom:5px; }
.pf-vital .vv { font-family:var(--font-en); font-weight:900; font-size:23px; color:var(--fg1); direction:ltr; }
.pf-vital .vv small { font-family:var(--font-ar); font-weight:700; font-size:11px; color:var(--fg3); margin-inline-start:2px; }
.pf-life { display:flex; flex-wrap:wrap; gap:8px; }
.pf-life .lp { font-family:var(--font-ar); font-weight:700; font-size:11.5px; padding:6px 12px; border-radius:999px;
  background:rgba(255,255,255,0.05); border:1px solid var(--stroke); color:var(--fg2); }
.pf-life .lp.warm { background:rgba(255,180,148,0.14); border-color:rgba(255,180,148,0.34); color:#FFD9C4; }
.pf-life .lp.ok { background:rgba(0,181,183,0.14); border-color:rgba(0,181,183,0.34); color:var(--brand-glow); }
.pf-acc { display:flex; flex-direction:column; gap:8px; }
.pf-acc .acc { display:flex; align-items:center; justify-content:space-between; padding:13px 15px; border-radius:var(--r-md);
  background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); }
.pf-acc .acc > span { display:flex; align-items:center; gap:10px; font-family:var(--font-ar); font-weight:700; font-size:13.5px; color:var(--fg1); }
.pf-acc .acc > span svg { width:16px; height:16px; color:var(--brand-glow); }
.pf-acc .acc > svg { width:17px; height:17px; color:var(--fg3); }

/* ----- Visit report mock ----- */
