   accounting glassy donut, analytics tabs/trend, date align
   ============================================================ */

/* ---- All-in-One block ---- */
.aio-sub { font-family:var(--font-en); font-weight:600; font-size:12.5px; letter-spacing:0.06em; color:var(--brand-glow); margin-top:8px; direction:ltr; }
.grad-acc { background:linear-gradient(120deg,#7DD3D4,#00B5B7); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
.merge-viz { position:relative; padding:30px 26px; display:flex; flex-direction:column; align-items:center; gap:0; overflow:hidden; }
.merge-viz .chaos { position:relative; width:100%; height:188px; }
.chaos-label { position:absolute; top:0; inset-inline-start:50%; transform:translateX(50%);
  font-family:var(--font-ar); font-weight:700; font-size:12px; color:var(--fg3); opacity:0.75;
  display:inline-flex; align-items:center; gap:7px; }
.chaos-label::before { content:""; width:6px; height:6px; border-radius:999px; background:#FF9E8A; box-shadow:0 0 10px #FF9E8A; }
.mchip { position:absolute; display:inline-flex; align-items:center; gap:7px; padding:8px 13px; border-radius:11px;
  font-family:var(--font-ar); font-weight:700; font-size:12.5px; color:var(--fg2); white-space:nowrap;
  background:rgba(255,255,255,0.05); border:1px solid var(--stroke-soft);
  box-shadow:0 8px 18px -8px rgba(0,16,21,0.6); filter:saturate(0.5); opacity:0.82; }
.mchip svg { width:14px; height:14px; color:var(--fg3); }
.mchip.m1 { top:34px; inset-inline-start:2%;  transform:rotate(-7deg); }
.mchip.m2 { top:30px; inset-inline-start:38%; transform:rotate(5deg); }
.mchip.m3 { top:40px; inset-inline-end:1%;   transform:rotate(8deg); }
.mchip.m4 { top:96px; inset-inline-start:9%;  transform:rotate(6deg); }
.mchip.m5 { top:104px; inset-inline-start:43%; transform:rotate(-5deg); }
.mchip.m6 { top:100px; inset-inline-end:8%;   transform:rotate(-9deg); }
.merge-funnel { display:flex; flex-direction:column; align-items:center; gap:3px; margin:2px 0 16px; }
.merge-funnel .mf-line { width:1px; height:16px; background:linear-gradient(var(--brand-glow),transparent); }
.merge-funnel .mf-line:last-child { background:linear-gradient(transparent,rgba(0,181,183,0.6)); }
.merge-funnel .mf-ico { width:30px; height:30px; border-radius:999px; display:grid; place-items:center;
  background:rgba(0,181,183,0.16); border:1px solid rgba(0,181,183,0.4); color:var(--brand-glow); }
.merge-funnel .mf-ico svg { width:16px; height:16px; }
.one-card { width:100%; position:relative; display:flex; align-items:center; gap:14px; padding:18px 20px; border-radius:var(--r-lg);
  background:linear-gradient(135deg, rgba(0,181,183,0.2), rgba(0,181,183,0.05));
  border:1px solid rgba(0,181,183,0.42); box-shadow:0 18px 40px -16px rgba(0,181,183,0.5), inset 0 1px 0 rgba(255,255,255,0.14); }
.one-card .oc-check { margin-inline-start:auto; width:30px; height:30px; flex:none; border-radius:999px; display:grid; place-items:center;
  background:linear-gradient(135deg,#7DD3D4,#00B5B7); color:#001015; box-shadow:0 6px 14px -4px rgba(0,181,183,0.6); }
.one-card .oc-check svg { width:17px; height:17px; }

/* ---- Patient documents strip ---- */
.pf-docs { margin-top:14px; padding-top:14px; border-top:1px solid var(--stroke); }
.pf-docs-h { display:flex; align-items:center; justify-content:space-between; margin-bottom:11px; }
.pf-docs-h > span:first-child { display:inline-flex; align-items:center; gap:8px; font-family:var(--font-ar); font-weight:800; font-size:13px; color:var(--fg2); }
.pf-docs-h svg { width:15px; height:15px; color:var(--brand-glow); }
.pf-docs-h .cnt2 { font-family:var(--font-ar); font-weight:700; font-size:11px; color:var(--brand-glow); background:rgba(0,181,183,0.14); padding:3px 10px; border-radius:999px; }
.pf-docs-row { display:grid; grid-template-columns:repeat(3,1fr); gap:9px; }
.pdoc { display:flex; flex-direction:column; align-items:center; gap:7px; padding:13px 8px; border-radius:var(--r-md);
  background:rgba(255,255,255,0.03); border:1px solid var(--stroke-soft); text-align:center; }
.pdoc .pd-ic { width:32px; height:32px; border-radius:10px; display:grid; place-items:center;
  background:rgba(0,181,183,0.12); color:var(--brand-glow); }
.pdoc .pd-ic svg { width:16px; height:16px; }
.pdoc .pd-n { font-family:var(--font-ar); font-weight:600; font-size:11px; color:var(--fg2); line-height:1.4; }
.pdoc .pd-t { font-family:var(--font-en); font-weight:700; font-size:9px; letter-spacing:0.05em; color:var(--fg3);
  background:rgba(255,255,255,0.06); padding:2px 8px; border-radius:6px; direction:ltr; }

/* ---- Appointments date alignment ---- */
.atr .ad { text-align:right; }
.ath span:first-child { text-align:right; }

/* ---- Billing 3-up bills grid ---- */
.bill-grid.three { grid-template-columns:repeat(3,1fr); }
@media (max-width:880px){ .bill-grid.three { grid-template-columns:1fr; } }

/* ---- Accounting / Analytics tabs ---- */
.acct-tabs { display:flex; gap:7px; margin-bottom:16px; }
.acct-tabs .at { flex:1; text-align:center; font-family:var(--font-ar); font-weight:700; font-size:12.5px; padding:9px 10px;
  border-radius:10px; background:rgba(255,255,255,0.035); border:1px solid var(--stroke-soft); color:var(--fg3); }
.acct-tabs .at.on { background:rgba(0,181,183,0.18); border-color:rgba(0,181,183,0.42); color:var(--brand-glow); }

/* ---- Glassy donut enhancement ---- */
.donut.glassy { filter:drop-shadow(0 14px 26px rgba(0,16,21,0.5)); }
.donut.glassy .donut-ring { box-shadow:inset 0 2px 6px rgba(255,255,255,0.14), inset 0 -8px 16px rgba(0,16,21,0.35); }
.donut.glassy .donut-ring::after { content:""; position:absolute; inset:0; border-radius:999px;
  background:radial-gradient(120px 80px at 30% 18%, rgba(255,255,255,0.28), transparent 60%);
  -webkit-mask:radial-gradient(farthest-side, transparent 58%, #000 59%);
  mask:radial-gradient(farthest-side, transparent 58%, #000 59%); pointer-events:none; }
.donut.glassy .donut-hole { box-shadow:inset 0 2px 8px rgba(0,16,21,0.6), inset 0 0 0 1px rgba(255,255,255,0.05); }
.donut.acct-d .donut-ring { background:conic-gradient(#00B5B7 0 57%, #0d8a8c 57% 79%, #7DD3D4 79% 89%, #C9A88A 89% 100%); }

/* legend with amounts */
.donut-legend.amt { gap:11px; }
.donut-legend.amt span { display:grid; grid-template-columns:auto 1fr; align-items:center; gap:0 9px; }
.donut-legend.amt em { font-style:normal; font-family:var(--font-ar); font-weight:700; font-size:12.5px; color:var(--fg2); }
.donut-legend.amt b { grid-column:2; font-family:var(--font-en); font-weight:700; font-size:11px; color:var(--fg3); direction:ltr; font-variant-numeric:tabular-nums; margin-top:1px; }
.donut-legend.amt i { grid-row:span 2; }

/* ---- Analytics ---- */
.an-kpibar.four { grid-template-columns:repeat(4,1fr); }
@media (max-width:880px){ .an-kpibar.four { grid-template-columns:repeat(2,1fr); } }
.an-svg { width:100%; height:72px; display:block; }
.an-svg .ln { fill:none; stroke-width:2.5; vector-effect:non-scaling-stroke; stroke-linecap:round; stroke-linejoin:round; }
.an-svg .ln.t { stroke:#00B5B7; }
.an-svg .ln.o { stroke:#FFB494; }
.reason-bars { display:flex; flex-direction:column; gap:13px; }
.rb .rb-top { display:flex; align-items:center; justify-content:space-between; margin-bottom:7px; }
.rb .rb-top span { font-family:var(--font-ar); font-weight:600; font-size:13px; color:var(--fg2); }
.rb .rb-top b { font-family:var(--font-en); font-weight:800; font-size:12.5px; color:var(--brand-glow); direction:ltr; }
.rb-bar { height:9px; border-radius:999px; background:rgba(255,255,255,0.07); overflow:hidden; }
.rb-bar i { display:block; height:100%; border-radius:999px; background:linear-gradient(90deg,#0a7173,#00B5B7); }

/* ============================================================
   STATIC EXPORT — no motion (high-quality PNG + print)
   ============================================================ */
/* motion enabled for the live web page (was disabled only for PNG/print export) */

/* ---- visible WhatsApp number ---- */
.wa-number { display:inline-flex; align-items:center; gap:10px; margin-top:18px; padding:11px 20px; border-radius:999px;
  text-decoration:none; font-family:var(--font-ar); font-weight:700; font-size:15px; color:var(--fg1);
  background:rgba(0,181,183,0.1); border:1px solid rgba(0,181,183,0.32); }
.wa-number i { width:18px; height:18px; color:var(--brand-glow); }
.wa-number span { color:var(--fg2); font-weight:600; }
.wa-number b { font-family:var(--font-en); font-weight:800; font-size:17px; color:var(--brand-glow);
  letter-spacing:0.04em; font-variant-numeric:tabular-nums; }
.foot-wa { display:inline-flex; align-items:center; gap:7px; margin-top:10px; white-space:nowrap; font-family:var(--font-ar);
  font-weight:700; font-size:13px; color:var(--fg2); }
.foot-wa i { width:15px; height:15px; color:var(--brand-glow); }
.foot-wa b { font-family:var(--font-en); font-weight:800; color:var(--brand-glow); letter-spacing:0.04em; }

/* ============================================================
   Print — tall poster export
   ============================================================ */
@media print {
  @page { margin:0; }
  body { background:#021015; -webkit-print-color-adjust:exact; print-color-adjust:exact; }
  .atmos { position:absolute; }
  .block, .hero, .closing, .feature, .growth, .tryfree { break-inside:avoid; }
  .no-print { display:none !important; }
}

/* ============================================================
   WEB — restored motion, scroll reveal, hover interactions
   ============================================================ */
/* floating 3D hero icon */
.hero-stage .hs-icon-wrap { animation:hsFloat 6s ease-in-out infinite; }

/* slow, unsynchronized orb drift in the fixed atmosphere */
@keyframes orbDrift { 0%,100%{ transform:translate(0,0) scale(1); } 50%{ transform:translate(20px,-26px) scale(1.06); } }
.atmos .orb { animation:orbDrift 20s ease-in-out infinite; will-change:transform; }
.atmos .orb:nth-child(2n) { animation-duration:25s; animation-direction:reverse; }
.atmos .orb:nth-child(3n) { animation-duration:30s; }

/* scroll-reveal (progressive enhancement: only hides when JS is on) */
.js .reveal { opacity:0; transform:translateY(28px);
  transition:opacity .7s cubic-bezier(.32,.72,0,1), transform .7s cubic-bezier(.32,.72,0,1); }
.js .reveal.in { opacity:1; transform:none; }

/* hover micro-interactions */
.icard, .qa, .fchip, .hs-chip, .offer-card, .gift, .loyalty {
  transition:transform .18s cubic-bezier(.32,.72,0,1), box-shadow .18s, border-color .18s; }
.icard:hover { transform:translateY(-3px); border-color:rgba(0,181,183,0.34); box-shadow:var(--shadow-lg); }
.qa:hover { border-color:rgba(0,181,183,0.3); }
.hs-chip:hover { transform:translateY(-3px); }
.btn-wa, .quiet { transition:transform .16s cubic-bezier(.32,.72,0,1), box-shadow .16s, color .16s; }

@media (prefers-reduced-motion:reduce){
  .hero-stage .hs-icon-wrap, .atmos .orb { animation:none !important; }
  .js .reveal { opacity:1 !important; transform:none !important; }
}

</style>
