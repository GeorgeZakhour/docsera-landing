/* ---------- Hero branded 3D stage ---------- */
.hero-stage { position:relative; aspect-ratio:1/1; max-width:480px; margin-inline:auto;
  display:grid; place-items:center; }
.hero-stage .hs-glow { position:absolute; width:82%; height:74%; border-radius:999px;
  background:radial-gradient(circle, rgba(0,181,183,0.28), rgba(0,181,183,0) 68%); filter:blur(56px); }
.hero-stage .hs-ring { position:absolute; border-radius:999px; border:1px solid rgba(125,211,212,0.18); }
.hero-stage .hs-ring.r1 { width:74%; height:74%; }
.hero-stage .hs-ring.r2 { width:99%; height:99%; border-color:rgba(125,211,212,0.10);
  border-style:dashed; }
.hero-stage .hs-icon-wrap { position:relative; width:60%; aspect-ratio:1/1; z-index:2;
  transform-style:preserve-3d;
  transform:perspective(1100px) rotateX(9deg) rotateY(-11deg) rotateZ(-1.5deg); }
/* contact shadow on the "floor" */
.hero-stage .hs-icon-wrap::before { content:""; position:absolute; left:8%; right:8%; bottom:-13%; height:20%;
  background:radial-gradient(ellipse at center, rgba(0,16,21,0.85), rgba(0,16,21,0) 72%);
  filter:blur(14px); transform:translateZ(-40px); z-index:-1; }
.hero-stage .hs-icon { display:block; width:100%; height:100%; object-fit:cover; border-radius:23%;
  box-shadow:
    0 3px 6px rgba(0,16,21,0.5),
    0 24px 44px -10px rgba(0,16,21,0.85),
    0 48px 90px -22px rgba(0,144,146,0.6),
    0 0 0 1px rgba(255,255,255,0.05),
    inset 0 3px 1px rgba(255,255,255,0.22),
    inset 0 -8px 18px rgba(0,16,21,0.5); }
/* glossy specular sheen across the top-left */
.hero-stage .hs-sheen { position:absolute; inset:0; border-radius:23%; pointer-events:none;
  background:linear-gradient(142deg, rgba(255,255,255,0.34) 0%, rgba(255,255,255,0.08) 22%, transparent 46%);
  mix-blend-mode:screen; opacity:0.9; }
@keyframes hsFloat {
  0%,100% { transform:perspective(1100px) rotateX(9deg) rotateY(-11deg) rotateZ(-1.5deg) translateY(0); }
  50%     { transform:perspective(1100px) rotateX(7deg) rotateY(-8deg)  rotateZ(-1deg)   translateY(-12px); }
}
@media (prefers-reduced-motion:reduce){ .hero-stage .hs-icon-wrap { animation:none; } }
.hero-stage .hs-chip { position:absolute; display:inline-flex; align-items:center; gap:8px;
  padding:9px 15px; border-radius:999px; z-index:3; white-space:nowrap;
  font-family:var(--font-ar); font-weight:700; font-size:13px; color:var(--fg1);
  background:linear-gradient(150deg, rgba(26,37,45,0.92), rgba(15,26,34,0.88));
  border:1px solid var(--stroke-strong);
  box-shadow:0 14px 30px -10px rgba(0,16,21,0.7), inset 0 1px 0 rgba(255,255,255,0.12);
  backdrop-filter:blur(6px); }
.hero-stage .hs-chip svg { width:15px; height:15px; color:var(--brand-glow); }
.hero-stage .hs-chip.c1 { top:6%; inset-inline-start:2%; }
.hero-stage .hs-chip.c2 { top:30%; inset-inline-end:-4%; }
.hero-stage .hs-chip.c3 { bottom:30%; inset-inline-start:-6%; }
.hero-stage .hs-chip.c4 { bottom:6%; inset-inline-end:4%; }
.hero-stage .hs-chip.c5 { top:-2%; inset-inline-end:24%; }
.hero-stage .hs-chip.c5 svg { color:var(--warm); }

