---
// Doctor landing page — rendered for every /doctor/<token> URL.
//
// Routing: this file builds to dist/doctor/index.html. The companion
// nginx rule (see nginx/default.conf) maps any /doctor/<anything> URL
// to this file via try_files fallback, so a single static page handles
// every doctor's token without rebuilds when new doctors are added.
//
// The page renders a loading shell on the server, then a small inline
// script reads the token from window.location.pathname, queries the
// public_doctors view via Supabase REST (anon read access, RLS-gated),
// and populates the DOM with the appropriate state:
//
//   - loading    initial state while the fetch is in-flight
//   - doctor     doctor found → render preview + device-aware CTA
//   - not-found  token didn't match an active doctor
//   - invalid    URL path didn't contain a token, or token failed
//                the safety regex (alnum + - + _, max 64 chars)
//
// Device-aware CTA branches:
//   - Mobile (iOS / Android): "Open in app" button using docsera:// scheme;
//     OS handles the Universal/App Link if the app is installed, otherwise
//     a pair of "Coming soon" App Store / Google Play badges (placeholder
//     until launch).
//   - Desktop: shows a QR code rendered client-side from the current URL,
//     so the visitor can scan with their phone to open in the app.

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Same anon Supabase credentials the patient app uses (lib/app/const.dart).
// Safe to embed client-side — RLS on public_doctors limits what anon reads.
const SUPABASE_URL = 'https://api.docsera.app';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzc0Mzg4NDY0LCJleHAiOjE5MzIwNjg0NjR9.Q9lVxKdVMbZge7vOgn_Ffroc8iVrpNtkFxqUugfwkPs';
---

<Layout title="DocSera — ملف الطبيب">
	<Navbar />

	<main class="doctor-page">
		<section class="doctor-section">
			<div class="container">

				<!-- Loading skeleton ------------------------------------ -->
				<div class="state state-loading" data-state="loading">
					<div class="spinner" aria-hidden="true"></div>
					<p>جارٍ تحميل بيانات الطبيب…</p>
				</div>

				<!-- Doctor preview + CTA -------------------------------- -->
				<div class="state state-doctor" data-state="doctor" hidden>
					<div class="doctor-card fade-up visible">
						<div class="doctor-photo">
							<!-- Initials fallback shown eagerly; the <img> is
							     stacked on top and only un-hides on successful
							     load. Avoids the "empty circle" intermediate
							     state if the image fetch is slow or fails. -->
							<div class="photo-fallback" data-doctor-fallback></div>
							<img data-doctor-image alt="" />
						</div>
						<div class="doctor-info">
							<span class="pill-badge specialty-badge" data-doctor-specialty></span>
							<h1 class="name" data-doctor-name></h1>
							<p class="clinic" data-doctor-clinic></p>
							<p class="address" data-doctor-address hidden>
								<svg class="pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
									<circle cx="12" cy="10" r="3"/>
								</svg>
								<span data-doctor-address-text></span>
							</p>
						</div>
					</div>

					<div class="cta-block fade-up visible">
						<h2 class="cta-title">احجز موعدك بسهولة عبر تطبيق DocSera</h2>
						<p class="cta-sub">صحتك بين يديك — مواعيد ومراسلات وتقارير في تطبيق واحد.</p>

						<!-- Mobile branch: open-in-app + store badges -->
						<div class="cta-mobile" data-cta-mobile>
							<a class="btn-main btn-open-app" data-open-app href="#" rel="noopener">
								افتح في التطبيق
							</a>
							<p class="cta-divider">حساب جديد؟ حمّل التطبيق</p>
							<div class="cta-stores">
								<!-- Pre-launch placeholders. Once the apps ship, swap the
								     outer <div class="store-link"> for an <a href="..."> with
								     the real store URL and remove the .is-coming-soon class
								     + the قريباً pill overlay. The SVG bodies stay as-is.

								     direction="ltr" on each SVG is required because the page
								     inherits dir="rtl" from <html> for Arabic content; without
								     the override the <text> elements paint right-to-left and
								     the label runs off the badge's left edge. -->
								<div class="store-link is-coming-soon" aria-label="App Store (قريباً)">
									<span class="coming-pill">قريباً</span>
									<svg class="store-badge" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 135 40" direction="ltr">
										<rect width="135" height="40" rx="6" fill="#000"/>
										<!-- Apple logo, Bootstrap Icons "apple" (16x16),
										     scaled 1.5x and centered in a 24x24 logo area. -->
										<g fill="#fff" transform="translate(10 8) scale(1.5)">
											<path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516.024.034 1.52.087 2.475-1.258.955-1.345.762-2.391.728-2.43zm3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422.212-2.189 1.675-2.789 1.698-2.854.023-.065-.597-.79-1.254-1.157a3.692 3.692 0 0 0-1.563-.434c-.108-.003-.486-.096-1.273.198-.517.193-1.682.645-2.003.659-.322.014-1.276-.529-2.304-.678-.656-.142-1.351.105-1.851.299-.5.196-1.448.77-2.114 2.279-.667 1.509-.32 3.899.165 5.726.485 1.828 1.331 3.473 2.247 3.66.685.139 1.498-.317 2.069-.514.572-.198 1.572-.236 2.426-.041.853.194 2.286.722 3.236.428.5-.156 1.473-.572 1.998-1.514.526-.942.752-1.86 1.022-2.708.274-.847.448-1.61.394-1.847z"/>
										</g>
										<text x="40" y="17" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="7" font-weight="400">Download on the</text>
										<text x="40" y="31" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="14" font-weight="600" letter-spacing="-0.4">App Store</text>
									</svg>
								</div>
								<div class="store-link is-coming-soon" aria-label="Google Play (قريباً)">
									<span class="coming-pill">قريباً</span>
									<svg class="store-badge" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 135 40" direction="ltr">
										<rect width="135" height="40" rx="6" fill="#000"/>
										<!-- Google Play play-triangle with the four official
										     brand colours rendered as a 3-stop gradient. Cleaner
										     than slicing the triangle into 4 sub-paths and reads
										     unmistakably as the Play badge mark. -->
										<defs>
											<linearGradient id="dsPlayGrad" x1="0" y1="0" x2="1" y2="1">
												<stop offset="0" stop-color="#EA4335"/>
												<stop offset=".45" stop-color="#FBBC04"/>
												<stop offset="1" stop-color="#34A853"/>
											</linearGradient>
										</defs>
										<g transform="translate(13 9.5)">
											<path fill="url(#dsPlayGrad)" d="M0 0 L0 21 L18 10.5 Z"/>
										</g>
										<text x="40" y="17" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="6.5" font-weight="400">GET IT ON</text>
										<text x="40" y="31" fill="#fff" font-family="Helvetica, Arial, sans-serif" font-size="14" font-weight="500" letter-spacing="-0.3">Google Play</text>
									</svg>
								</div>
							</div>
						</div>

						<!-- Desktop branch: QR code -->
						<div class="cta-desktop" data-cta-desktop hidden>
							<p class="cta-desk-instr">امسح رمز QR من كاميرا هاتفك لفتح ملف الطبيب في تطبيق DocSera</p>
							<div class="qr-frame">
								<div class="qr-canvas" data-qr-canvas></div>
							</div>
							<p class="cta-desk-tip">إذا لم يكن لديك التطبيق، سيفتح الرابط على هاتفك بعد التثبيت.</p>
						</div>
					</div>
				</div>

				<!-- Doctor not found ----------------------------------- -->
				<div class="state state-not-found" data-state="not-found" hidden>
					<div class="error-card fade-up visible">
						<div class="error-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<circle cx="12" cy="12" r="10"/>
								<line x1="12" y1="8" x2="12" y2="12"/>
								<line x1="12" y1="16" x2="12.01" y2="16"/>
							</svg>
						</div>
						<h1>لم نعثر على هذا الطبيب</h1>
						<p>قد يكون الرابط منتهي الصلاحية أو حذف الطبيب ملفه. تحقق من الرابط وحاول مرة أخرى.</p>
						<a href="/" class="btn-main">العودة للرئيسية</a>
					</div>
				</div>

				<!-- Invalid token format ------------------------------- -->
				<div class="state state-invalid" data-state="invalid" hidden>
					<div class="error-card fade-up visible">
						<div class="error-icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<circle cx="12" cy="12" r="10"/>
								<line x1="15" y1="9" x2="9" y2="15"/>
								<line x1="9" y1="9" x2="15" y2="15"/>
							</svg>
						</div>
						<h1>رابط غير صحيح</h1>
						<p>الرابط لا يحتوي على معرّف طبيب صالح. الرجاء العودة للرئيسية.</p>
						<a href="/" class="btn-main">العودة للرئيسية</a>
					</div>
				</div>

			</div>
		</section>
	</main>

	<Footer />
</Layout>

<script>
	import qrcode from 'qrcode-generator';

	// Constants are injected at build time from the page frontmatter
	// via a window global to keep this script type-clean for the bundler.
	const SUPABASE_URL = 'https://api.docsera.app';
	const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzc0Mzg4NDY0LCJleHAiOjE5MzIwNjg0NjR9.Q9lVxKdVMbZge7vOgn_Ffroc8iVrpNtkFxqUugfwkPs';

	// ----- Token extraction & validation ----------------------
	const path = window.location.pathname;
	const match = path.match(/^\/doctor\/([^/?#]+)/);
	if (!match) {
		showState('invalid');
	} else {
		const token = decodeURIComponent(match[1]);

		// Same constraint the deep-link handler in the patient app uses
		// (services/navigation/deep_link_service.dart): alnum + - + _,
		// max 64 chars. Reject anything else as malformed.
		if (!/^[A-Za-z0-9_-]{1,64}$/.test(token)) {
			showState('invalid');
		} else {
			fetchDoctor(token);
		}
	}

	function fetchDoctor(token: string) {
		// ----- Device detection ----------------------------------
		const ua = navigator.userAgent || '';
		const isIOS = /iPad|iPhone|iPod/.test(ua) && !(window as any).MSStream;
		const isAndroid = /Android/i.test(ua);
		const isMobile = isIOS || isAndroid;

		// Only the columns we actually render — avoids pulling internal
		// fields from the view even though RLS already gates them.
		const select = [
			'id',
			'public_token',
			'first_name',
			'middle_name',
			'last_name',
			'title',
			'specialty',
			'specialties',
			'gender',
			'doctor_image',
			'clinic',
			'address',
		].join(',');

		const url = SUPABASE_URL + '/rest/v1/public_doctors' +
			'?select=' + encodeURIComponent(select) +
			'&public_token=eq.' + encodeURIComponent(token) +
			'&is_active=eq.true' +
			'&limit=1';

		fetch(url, {
			headers: {
				apikey: SUPABASE_ANON_KEY,
				Authorization: 'Bearer ' + SUPABASE_ANON_KEY,
			},
		})
			.then((r) => {
				if (!r.ok) throw new Error('HTTP ' + r.status);
				return r.json();
			})
			.then((rows: any[]) => {
				if (!Array.isArray(rows) || rows.length === 0) {
					showState('not-found');
					return;
				}
				renderDoctor(rows[0], token, isMobile);
			})
			.catch((err) => {
				console.error('[doctor page] fetch failed:', err);
				showState('not-found');
			});
	}

	function renderDoctor(d: any, token: string, isMobile: boolean) {
		const titlePart = (d.title || '').trim();
		const namePart = [d.first_name, d.middle_name, d.last_name]
			.map((s: any) => (s || '').trim())
			.filter(Boolean)
			.join(' ');
		const fullName = [titlePart, namePart].filter(Boolean).join(' ').trim();

		byData('doctor-name').textContent = fullName || 'طبيب';
		document.title = fullName ? (fullName + ' — DocSera') : 'DocSera — ملف الطبيب';

		const spec = d.specialty ||
			(Array.isArray(d.specialties) && d.specialties.length > 0
				? d.specialties[0]
				: '');
		byData('doctor-specialty').textContent = spec || 'طبيب';

		byData('doctor-clinic').textContent = d.clinic || '';

		// Address — formatted from the jsonb column, falls back gracefully
		// when fields are missing. Hidden entirely if no address at all.
		const addrText = formatAddress(d.address);
		if (addrText) {
			byData('doctor-address-text').textContent = addrText;
			byData('doctor-address').hidden = false;
		}

		renderImage(d, fullName);
		renderCta(d, token, isMobile);

		showState('doctor');
	}

	function formatAddress(addr: any): string {
		if (!addr || typeof addr !== 'object') return '';
		// Compose "street، neighborhood، city" with whichever parts exist,
		// preferring the most specific. Strip neighborhood's parenthesised
		// detail so we don't end up with "المزة (فيلات، أوتوستراد، شيخ سعد)"
		// inline — the parens fight with the surrounding RTL comma-list.
		const street = (addr.street || '').trim();
		const rawHood = (addr.neighborhood || '').trim();
		const hood = rawHood.replace(/\s*\([^)]*\)\s*$/, '').trim();
		const city = (addr.city || '').trim();
		const parts: string[] = [];
		if (street) parts.push(street);
		if (hood && hood !== street && hood !== city) parts.push(hood);
		if (city) parts.push(city);
		return parts.join('، ');
	}

	function renderImage(d: any, fullName: string) {
		const img = byData('doctor-image') as HTMLImageElement;
		const fb = byData('doctor-fallback');

		// Always populate the fallback initials first, so the circle is
		// never blank even if the image hasn't started loading yet.
		fb.textContent = initialsFor(d);

		const path = (d.doctor_image || '').trim();
		if (!path) {
			img.hidden = true;
			return;
		}

		// Preserve slashes in the path (it's typically uuid/profile/file.ext)
		// while still escaping any unsafe characters within each segment.
		const url = SUPABASE_URL + '/storage/v1/object/public/doctor/' +
			path.split('/').map((seg: string) => encodeURIComponent(seg)).join('/');

		img.alt = fullName;
		img.onload = () => {
			// Reveal the image — it now sits on top of the initials fallback
			// (z-index in CSS), so the fallback is hidden visually.
			img.classList.add('is-loaded');
		};
		img.onerror = () => {
			img.hidden = true;
			// fallback initials are already populated and visible
		};
		img.src = url;
	}

	function initialsFor(d: any): string {
		const a = ((d.first_name || '').trim().charAt(0) || '');
		const b = ((d.last_name || '').trim().charAt(0) || '');
		return (a + b).toUpperCase() || '?';
	}

	function renderCta(d: any, token: string, isMobile: boolean) {
		// Always wire the in-app deep-link so installed users can
		// "Open in app". OS routes docsera://doctor/<token> if the
		// app is installed; if not, browsers just no-op (which is
		// fine — the stores badges are the fallback for new users).
		const inAppUrl = 'docsera://doctor/' + encodeURIComponent(token);
		const openBtn = byData('open-app') as HTMLAnchorElement;
		openBtn.href = inAppUrl;

		// Device-aware visibility
		const ctaMobile = byData('cta-mobile');
		const ctaDesktop = byData('cta-desktop');
		if (isMobile) {
			ctaMobile.hidden = false;
			ctaDesktop.hidden = true;
		} else {
			ctaMobile.hidden = true;
			ctaDesktop.hidden = false;
			renderQrCode();
		}
	}

	function renderQrCode() {
		const container = byData('qr-canvas');
		if (!container) return;
		const url = window.location.href;
		// Type 0 = auto-pick smallest QR version that fits the data.
		// Error correction 'M' (~15%) balances density vs scannability —
		// the doctor URL is short (~50 chars), 'M' is plenty robust.
		const qr = qrcode(0, 'M');
		qr.addData(url);
		qr.make();
		// Render as inline SVG, scalable to the container's CSS size.
		container.innerHTML = qr.createSvgTag({ scalable: true, margin: 2 });
	}

	// ----- Tiny DOM helpers -----------------------------------
	function byData(name: string): HTMLElement {
		return document.querySelector('[data-' + name + ']') as HTMLElement;
	}

	function showState(state: string) {
		document.querySelectorAll<HTMLElement>('[data-state]').forEach((el) => {
			el.hidden = el.dataset.state !== state;
		});
	}
</script>

<style>
	main { overflow-x: hidden; }

	.doctor-section {
		padding: 140px 0 80px;
		min-height: 80vh;
		background: radial-gradient(circle at 10% 10%, #fff 0%, #FAFAFA 100%);
	}

	/* ----- States ----- */
	.state { text-align: center; }
	.state[hidden] { display: none !important; }

	/* Loading */
	.state-loading p { color: var(--c-text-muted); margin-top: 16px; }
	.spinner {
		width: 44px; height: 44px; margin: 0 auto;
		border: 3px solid var(--c-main-light);
		border-top-color: var(--c-main);
		border-radius: 50%;
		animation: spin 0.8s linear infinite;
	}
	@keyframes spin { to { transform: rotate(360deg); } }

	/* Doctor card */
	.doctor-card {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 32px;
		align-items: center;
		background: white;
		padding: 36px;
		border-radius: 28px;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.05);
		margin: 0 auto 24px;
		max-width: 720px;
		text-align: right;
	}

	/* Photo with initials-first fallback strategy.
	   Stack: fallback initials at z-index 1, <img> at z-index 2.
	   The img is invisible by default (opacity 0) so the fallback shows
	   through; on successful load .is-loaded sets opacity 1, covering it. */
	.doctor-photo {
		width: 128px; height: 128px;
		border-radius: 50%;
		overflow: hidden;
		position: relative;
		flex-shrink: 0;
		background: var(--c-main-light);
	}
	.doctor-photo img {
		position: absolute; inset: 0;
		width: 100%; height: 100%;
		object-fit: cover;
		display: block;
		z-index: 2;
		opacity: 0;
		transition: opacity 0.25s ease-out;
	}
	.doctor-photo img.is-loaded { opacity: 1; }
	.photo-fallback {
		position: absolute; inset: 0;
		display: flex; align-items: center; justify-content: center;
		font-family: var(--font-en);
		font-size: 2.2rem;
		font-weight: 700;
		color: var(--c-main);
		background: var(--c-main-light);
		z-index: 1;
	}
	.doctor-info .pill-badge {
		display: inline-block;
		background: rgba(0, 144, 146, 0.1);
		color: var(--c-main);
		padding: 6px 14px;
		border-radius: 20px;
		font-weight: 700;
		font-size: 0.85rem;
		margin-bottom: 10px;
	}
	.doctor-info .name {
		font-size: clamp(1.5rem, 3.2vw, 2rem);
		font-weight: 800;
		line-height: 1.2;
		margin: 0 0 8px;
		color: var(--c-text);
	}
	.doctor-info .clinic {
		color: var(--c-text-muted);
		font-size: 1rem;
		margin: 0 0 6px;
	}
	.doctor-info .address {
		color: var(--c-text-muted);
		font-size: 0.92rem;
		margin: 6px 0 0;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		line-height: 1.4;
	}
	.doctor-info .address .pin {
		width: 14px; height: 14px;
		color: var(--c-main);
		flex-shrink: 0;
	}

	/* CTA block */
	.cta-block {
		background: white;
		padding: 40px 32px;
		border-radius: 28px;
		text-align: center;
		max-width: 720px;
		margin: 0 auto;
		box-shadow: 0 20px 60px rgba(0, 0, 0, 0.04);
	}
	.cta-title {
		font-size: clamp(1.2rem, 2.4vw, 1.6rem);
		font-weight: 800;
		margin-bottom: 10px;
		color: var(--c-text);
	}
	.cta-sub {
		color: var(--c-text-muted);
		margin: 0 0 28px;
		font-size: 1rem;
	}

	.btn-main {
		background: var(--c-main);
		color: white;
		padding: 14px 32px;
		border-radius: 12px;
		font-weight: 700;
		text-decoration: none;
		display: inline-block;
		font-size: 1rem;
		transition: background 0.2s;
	}
	.btn-main:hover { background: var(--c-main-dark); }

	.btn-open-app {
		padding: 16px 40px;
		font-size: 1.1rem;
	}

	.cta-divider {
		margin: 22px 0 14px;
		color: var(--c-text-muted);
		font-size: 0.9rem;
	}

	/* App Store / Google Play badges — match the official store-badge
	   look (rounded-rect black tile with brand mark + label). When stores
	   ship, swap the outer <div class="store-link"> for an <a href="...">
	   and remove .is-coming-soon + the قريباً pill in the markup. */
