---
import Layout from '../layouts/Layout.astro';
---

<Layout title="الصفحة غير موجودة — DocSera" path="/404.html">
	<main class="nf-wrap">
		<div class="nf-card">
			<img src="/images/docsera_main.svg" alt="DocSera" class="nf-logo" />
			<div class="nf-code font-en">404</div>
			<h1>الصفحة غير موجودة</h1>
			<p>الرابط الذي تبحث عنه غير موجود أو تم نقله. تحقق من العنوان أو عد إلى الصفحة الرئيسية.</p>
			<a href="/" class="nf-btn">العودة للرئيسية</a>
		</div>
	</main>
</Layout>

<style>
	.nf-wrap {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px;
		background: linear-gradient(180deg, #FAFAFA 0%, var(--c-main-light) 100%);
	}

	.nf-card {
		text-align: center;
		max-width: 420px;
	}

	.nf-logo {
		height: 28px;
		margin-bottom: 32px;
	}

	.nf-code {
		font-size: 5rem;
		font-weight: 700;
		line-height: 1;
		color: var(--c-main);
		opacity: 0.25;
		margin-bottom: 8px;
	}

	h1 {
		font-size: 1.6rem;
		margin-bottom: 12px;
	}

	p {
		color: var(--c-text-muted);
		font-size: 1rem;
		margin: 0 0 28px;
	}

	.nf-btn {
		display: inline-block;
		background: var(--c-main);
		color: var(--c-white);
		padding: 12px 32px;
		border-radius: 12px;
		text-decoration: none;
		font-weight: 600;
		transition: background 0.2s ease;
	}

	.nf-btn:hover {
		background: var(--c-main-dark);
	}
</style>
